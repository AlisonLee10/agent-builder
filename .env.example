# Copy to .env and fill in real values. Never commit .env to git.
OPENAI_API_KEY=sk-your-openai-key
WEBHOOK_URL=https://discord.com/api/webhooks/your-webhook-id/your-token
NEWS_API_KEY=your-newsapi-key
SERP_API_KEY=your-serpapi-key

# LangSmith (optional tracing)
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=lsv2_your-langsmith-key
LANGCHAIN_PROJECT=marketing-agent

# MCP / integrations
TAVILY_API_KEY=tvly-your-tavily-key
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
SLACK_TEAM_ID=T00000000
SLACK_CHANNEL_ID=C00000000

# Gmail (optional) — service account with domain-wide delegation
GMAIL_SERVICE_ACCOUNT_FILE=gmail_credentials.json
GMAIL_SENDER_EMAIL=you@yourdomain.com
GMAIL_TEST_RECIPIENT=you@example.com
GMAIL_DEFAULT_SUBJECT=Marketing Update
